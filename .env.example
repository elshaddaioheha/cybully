# Shared local defaults. Copy to .env for local or hosted setup.
ENVIRONMENT=development

# Backend / Next.js BFF
API_BASE_URL=http://localhost:8000
# Optional fallback for non-user service calls and manual local scripts.
BACKEND_INTERNAL_TOKEN=dev-internal-token
ALLOWED_CORS_ORIGINS=http://localhost:3000

# Supabase Postgres. For local Windows/IPv4 access, prefer the Session Pooler string from Supabase.
# Percent-encode reserved password characters such as $ as %24 and % as %25.
DATABASE_URL=postgresql://postgres.YOUR_PROJECT_REF:YOUR_PERCENT_ENCODED_PASSWORD@aws-1-YOUR-REGION.pooler.supabase.com:5432/postgres?sslmode=require
SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
SUPABASE_PUBLISHABLE_KEY=replace-with-supabase-publishable-key
SUPABASE_SECRET_KEY=replace-with-supabase-secret-key
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=replace-with-supabase-publishable-key
PIPELINE_MODE=direct
SCORER_PROVIDER=auto

# Optional queue mode settings. Only needed when PIPELINE_MODE=queue.
RABBITMQ_URL=amqp://cybully:cybully@rabbitmq:5672/
MODEL_INFERENCE_DEVICE=cpu
DETOXIFY_MODEL_NAME=unbiased
RISK_THRESHOLD_MEDIUM=0.4
RISK_THRESHOLD_HIGH=0.7
RISK_WEIGHT_INTENT=0.25
RISK_WEIGHT_REPETITION=0.25
RISK_WEIGHT_AGGRESSION=0.5
REPETITION_WINDOW_HOURS=48
REPETITION_DECAY=0.7
ADMIN_NOTIFICATION_EMAIL=moderation@example.com

# Frontend and backend moderator role gating
MODERATOR_EMAILS=moderator@example.com,pascaladerinola082@gmail.com,pascaladerinola073@gmail.com
NEXT_PUBLIC_APP_NAME=Cybully Safety
